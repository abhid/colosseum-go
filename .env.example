OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required before storing secrets in Colosseum.
COLOSSEUM_SECRET_KEY=change-me-generate-a-long-random-value

# Recommended whenever the server is reachable beyond localhost.
COLOSSEUM_API_AUTH_TOKEN=change-me-generate-a-long-random-token

COLOSSEUM_LISTEN_IP=127.0.0.1
COLOSSEUM_PORT=8080
COLOSSEUM_DB_PATH=./colosseum.db
COLOSSEUM_ARTIFACT_PATH=./artifacts
COLOSSEUM_WORKSPACE_ROOT=./workspaces

COLOSSEUM_BROWSER_MODE=docker
COLOSSEUM_BROWSER_IMAGE=mcr.microsoft.com/playwright:v1.59.1-jammy
COLOSSEUM_BROWSER_FALLBACK=true
